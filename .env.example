# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FILTER_MODEL=claude-haiku-4-5-20251001

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Upwork OAuth (apply at upwork.com/developer/portal)
UPWORK_CLIENT_ID=your_upwork_client_id_here
UPWORK_CLIENT_SECRET=your_upwork_client_secret_here
UPWORK_ACCESS_TOKEN=your_upwork_access_token_here
UPWORK_REFRESH_TOKEN=your_upwork_refresh_token_here
