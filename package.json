{
  "name": "upwork-proposal-machine",
  "version": "1.0.0",
  "description": "Upwork job monitor + Claude-powered proposal generator",
  "main": "dist/monitor.js",
  "scripts": {
    "build": "tsc",
    "setup": "ts-node monitor.ts --setup",
    "start": "ts-node monitor.ts --start",
    "dev": "ts-node --transpile-only monitor.ts --start",
    "watch": "node --watch --loader ts-node/esm monitor.ts --start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.5.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
